<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>$(DefaultTargetFrameworks)</TargetFramework>
        <PublishAot>true</PublishAot>
        <SelfContained>true</SelfContained>
        <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
        <TrimmerSingleWarn>false</TrimmerSingleWarn>
        <RootNamespace>ActionsToolkit.Attest.AotConsumer</RootNamespace>
        <AssemblyName>actions-toolkit-attest-aot-consumer</AssemblyName>
        <IsPackable>false</IsPackable>
        <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
        <GenerateDocumentationFile>false</GenerateDocumentationFile>
        <EnableTestSdk>false</EnableTestSdk>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\..\src\ActionsToolkit.Attest\ActionsToolkit.Attest.csproj" />
        <ProjectReference Include="..\..\..\src\ActionsToolkit.Octokit\ActionsToolkit.Octokit.csproj" />
        <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
        <PackageReference Include="Microsoft.Extensions.Http" />
    </ItemGroup>
</Project>
